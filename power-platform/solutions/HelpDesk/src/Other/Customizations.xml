              <RequiredLevel>required</RequiredLevel>
            </attribute>
            <attribute PhysicalName="hd_firstresponseminutes">
              <Type>int</Type>
              <RequiredLevel>required</RequiredLevel>
            </attribute>
            <attribute PhysicalName="hd_resolutionminutes">
              <Type>int</Type>
              <RequiredLevel>required</RequiredLevel>
            </attribute>
            <attribute PhysicalName="hd_businesshoursonly">
              <Type>bit</Type>
              <DefaultValue>1</DefaultValue>
            </attribute>
            <attribute PhysicalName="hd_priority">
