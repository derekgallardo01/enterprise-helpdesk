<?xml version="1.0" encoding="utf-8"?>
<ImportExportXml xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <Entities>
    <!-- ============================================================ -->
    <!-- hd_ticket — Primary ticketing entity                         -->
    <!-- ============================================================ -->
    <Entity>
      <Name LocalizedName="Ticket" OriginalName="hd_ticket">hd_ticket</Name>
      <ObjectTypeCode>10000</ObjectTypeCode>
      <EntityInfo>
        <entity Name="hd_ticket">
          <LocalizedNames>
            <LocalizedName description="Ticket" languagecode="1033" />
          </LocalizedNames>
          <Descriptions>
            <Description description="The primary IT help desk ticket entity." languagecode="1033" />
          </Descriptions>
          <attributes>
            <attribute PhysicalName="hd_ticketid">
              <Type>primarykey</Type>
              <IsCustomField>1</IsCustomField>
              <DisplayMask>ValidForAdvancedFind|ValidForForm|ValidForGrid</DisplayMask>
            </attribute>
            <attribute PhysicalName="hd_ticketnumber">
              <Type>nvarchar</Type>
              <MaxLength>20</MaxLength>
              <AutoNumberFormat>TKT-{SEQNUM:6}</AutoNumberFormat>
              <DisplayMask>ValidForAdvancedFind|ValidForForm|ValidForGrid</DisplayMask>
            </attribute>
            <attribute PhysicalName="hd_title">
              <Type>nvarchar</Type>
              <MaxLength>200</MaxLength>
              <RequiredLevel>required</RequiredLevel>
            </attribute>
            <attribute PhysicalName="hd_description">
              <Type>ntext</Type>
              <Format>RichText</Format>
              <RequiredLevel>required</RequiredLevel>
            </attribute>
            <attribute PhysicalName="hd_priority">
              <Type>picklist</Type>
              <OptionSetName>hd_ticketpriority</OptionSetName>
            </attribute>
            <attribute PhysicalName="hd_status">
              <Type>picklist</Type>
              <OptionSetName>hd_ticketstatus</OptionSetName>
            </attribute>
            <attribute PhysicalName="hd_category">
              <Type>lookup</Type>
              <LookupType>hd_category</LookupType>
              <RequiredLevel>required</RequiredLevel>
            </attribute>
            <attribute PhysicalName="hd_subcategory">
              <Type>lookup</Type>
              <LookupType>hd_subcategory</LookupType>
            </attribute>
            <attribute PhysicalName="hd_requestedby">
              <Type>lookup</Type>
              <LookupType>systemuser</LookupType>
            </attribute>
            <attribute PhysicalName="hd_assignedto">
              <Type>lookup</Type>
              <LookupType>systemuser</LookupType>
            </attribute>
            <attribute PhysicalName="hd_assignedteam">
              <Type>lookup</Type>
              <LookupType>team</LookupType>
            </attribute>
            <attribute PhysicalName="hd_impact">
              <Type>picklist</Type>
              <OptionSetName>hd_ticketimpact</OptionSetName>
            </attribute>
            <attribute PhysicalName="hd_urgency">
              <Type>picklist</Type>
              <OptionSetName>hd_ticketurgency</OptionSetName>
            </attribute>
            <attribute PhysicalName="hd_source">
              <Type>picklist</Type>
              <OptionSetName>hd_ticketsource</OptionSetName>
            </attribute>
            <attribute PhysicalName="hd_duedate">
              <Type>datetime</Type>
            </attribute>
            <attribute PhysicalName="hd_resolutiondate">
              <Type>datetime</Type>
            </attribute>
            <attribute PhysicalName="hd_firstresponseat">
              <Type>datetime</Type>
            </attribute>
            <attribute PhysicalName="hd_slabreach">
              <Type>bit</Type>
              <DefaultValue>0</DefaultValue>
            </attribute>
            <attribute PhysicalName="hd_resolutionnotes">
              <Type>ntext</Type>
            </attribute>
            <attribute PhysicalName="hd_satisfactionrating">
              <Type>int</Type>
              <MinValue>1</MinValue>
              <MaxValue>5</MaxValue>
            </attribute>
            <attribute PhysicalName="hd_relatedasset">
              <Type>lookup</Type>
              <LookupType>hd_asset</LookupType>
            </attribute>
            <attribute PhysicalName="hd_environment">
              <Type>picklist</Type>
              <OptionSetName>hd_ticketenvironment</OptionSetName>
            </attribute>
          </attributes>
        </entity>
      </EntityInfo>
    </Entity>

    <!-- ============================================================ -->
    <!-- hd_ticketcomment — Child conversation thread                 -->
    <!-- ============================================================ -->
    <Entity>
      <Name LocalizedName="Ticket Comment" OriginalName="hd_ticketcomment">hd_ticketcomment</Name>
      <ObjectTypeCode>10001</ObjectTypeCode>
      <EntityInfo>
        <entity Name="hd_ticketcomment">
          <LocalizedNames>
            <LocalizedName description="Ticket Comment" languagecode="1033" />
          </LocalizedNames>
          <attributes>
            <attribute PhysicalName="hd_ticketcommentid">
              <Type>primarykey</Type>
            </attribute>
            <attribute PhysicalName="hd_ticket">
              <Type>lookup</Type>
              <LookupType>hd_ticket</LookupType>
              <CascadeAssign>NoCascade</CascadeAssign>
              <CascadeDelete>Cascade</CascadeDelete>
            </attribute>
            <attribute PhysicalName="hd_commentbody">
              <Type>ntext</Type>
              <Format>RichText</Format>
            </attribute>
            <attribute PhysicalName="hd_commenttype">
              <Type>picklist</Type>
              <OptionSetName>hd_commenttype</OptionSetName>
            </attribute>
          </attributes>
        </entity>
      </EntityInfo>
    </Entity>

    <!-- ============================================================ -->
    <!-- hd_category — Top-level classification                       -->
    <!-- ============================================================ -->
    <Entity>
      <Name LocalizedName="Category" OriginalName="hd_category">hd_category</Name>
      <ObjectTypeCode>10002</ObjectTypeCode>
      <EntityInfo>
        <entity Name="hd_category">
          <LocalizedNames>
            <LocalizedName description="Category" languagecode="1033" />
          </LocalizedNames>
          <attributes>
            <attribute PhysicalName="hd_categoryid">
              <Type>primarykey</Type>
            </attribute>
            <attribute PhysicalName="hd_name">
              <Type>nvarchar</Type>
              <MaxLength>100</MaxLength>
              <RequiredLevel>required</RequiredLevel>
            </attribute>
            <attribute PhysicalName="hd_description">
              <Type>ntext</Type>
            </attribute>
            <attribute PhysicalName="hd_isactive">
              <Type>bit</Type>
              <DefaultValue>1</DefaultValue>
            </attribute>
            <attribute PhysicalName="hd_defaultteam">
              <Type>lookup</Type>
              <LookupType>team</LookupType>
            </attribute>
            <attribute PhysicalName="hd_sortorder">
              <Type>int</Type>
            </attribute>
          </attributes>
        </entity>
      </EntityInfo>
    </Entity>

    <!-- ============================================================ -->
    <!-- hd_subcategory — Second-level classification                 -->
    <!-- ============================================================ -->
    <Entity>
      <Name LocalizedName="Subcategory" OriginalName="hd_subcategory">hd_subcategory</Name>
      <ObjectTypeCode>10003</ObjectTypeCode>
      <EntityInfo>
        <entity Name="hd_subcategory">
          <LocalizedNames>
            <LocalizedName description="Subcategory" languagecode="1033" />
          </LocalizedNames>
          <attributes>
            <attribute PhysicalName="hd_subcategoryid">
              <Type>primarykey</Type>
            </attribute>
            <attribute PhysicalName="hd_name">
              <Type>nvarchar</Type>
              <MaxLength>100</MaxLength>
              <RequiredLevel>required</RequiredLevel>
            </attribute>
            <attribute PhysicalName="hd_category">
              <Type>lookup</Type>
              <LookupType>hd_category</LookupType>
              <CascadeAssign>NoCascade</CascadeAssign>
              <CascadeDelete>Cascade</CascadeDelete>
            </attribute>
            <attribute PhysicalName="hd_defaultpriority">
              <Type>picklist</Type>
              <OptionSetName>hd_ticketpriority</OptionSetName>
            </attribute>
            <attribute PhysicalName="hd_slaprofile">
              <Type>lookup</Type>
              <LookupType>hd_slaprofile</LookupType>
            </attribute>
            <attribute PhysicalName="hd_isactive">
              <Type>bit</Type>
              <DefaultValue>1</DefaultValue>
            </attribute>
          </attributes>
        </entity>
      </EntityInfo>
    </Entity>

    <!-- ============================================================ -->
    <!-- hd_asset — IT asset tracking                                 -->
    <!-- ============================================================ -->
    <Entity>
      <Name LocalizedName="Asset" OriginalName="hd_asset">hd_asset</Name>
      <ObjectTypeCode>10004</ObjectTypeCode>
      <EntityInfo>
        <entity Name="hd_asset">
