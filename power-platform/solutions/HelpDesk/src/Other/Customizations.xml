  <!-- ============================================================ -->
  <!-- Security Roles                                               -->
  <!-- ============================================================ -->
  <Roles>
    <Role name="HD - Administrator" id="{00000000-0000-0000-0000-000000000001}">
      <Description>Full control over all Help Desk entities. Can manage categories, SLA profiles, departments, and all tickets. Intended for IT leadership and platform administrators.</Description>
    </Role>
    <Role name="HD - Agent" id="{00000000-0000-0000-0000-000000000002}">
      <Description>Can read, create, update, and resolve tickets. Can add public and internal comments. Can view all tickets in their team. Cannot modify categories, SLA profiles, or departments.</Description>
    </Role>
    <Role name="HD - Manager" id="{00000000-0000-0000-0000-000000000003}">
      <Description>Everything an Agent can do, plus reassign tickets across teams, view reporting dashboards, and manage team-scoped configuration. Cannot modify global settings.</Description>
    </Role>
    <Role name="HD - Requester" id="{00000000-0000-0000-0000-000000000004}">
      <Description>Can create tickets, view their own tickets, add public comments to their own tickets, and submit satisfaction ratings. Cannot see internal comments or other users tickets.</Description>
    </Role>
  </Roles>
</ImportExportXml>
