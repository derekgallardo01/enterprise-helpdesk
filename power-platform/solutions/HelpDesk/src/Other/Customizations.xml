          </LocalizedNames>
          <attributes>
            <attribute PhysicalName="hd_assetid">
              <Type>primarykey</Type>
            </attribute>
            <attribute PhysicalName="hd_assettag">
              <Type>nvarchar</Type>
              <MaxLength>20</MaxLength>
              <AutoNumberFormat>AST-{SEQNUM:5}</AutoNumberFormat>
            </attribute>
            <attribute PhysicalName="hd_name">
              <Type>nvarchar</Type>
              <MaxLength>200</MaxLength>
              <RequiredLevel>required</RequiredLevel>
            </attribute>
            <attribute PhysicalName="hd_assettype">
              <Type>picklist</Type>
              <OptionSetName>hd_assettype</OptionSetName>
            </attribute>
            <attribute PhysicalName="hd_status">
              <Type>picklist</Type>
              <OptionSetName>hd_assetstatus</OptionSetName>
            </attribute>
            <attribute PhysicalName="hd_assignedto">
              <Type>lookup</Type>
              <LookupType>systemuser</LookupType>
            </attribute>
            <attribute PhysicalName="hd_department">
              <Type>lookup</Type>
              <LookupType>hd_department</LookupType>
            </attribute>
            <attribute PhysicalName="hd_purchasedate">
              <Type>datetime</Type>
              <Format>DateOnly</Format>
            </attribute>
            <attribute PhysicalName="hd_warrantyexpiry">
              <Type>datetime</Type>
              <Format>DateOnly</Format>
            </attribute>
            <attribute PhysicalName="hd_serialnumber">
              <Type>nvarchar</Type>
              <MaxLength>100</MaxLength>
            </attribute>
          </attributes>
        </entity>
      </EntityInfo>
    </Entity>

    <!-- ============================================================ -->
