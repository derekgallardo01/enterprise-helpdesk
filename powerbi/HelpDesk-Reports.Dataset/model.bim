          {
            "name": "PriorityLabel",
            "dataType": "string",
            "isDataTypeInferred": false,
            "expression": "SWITCH([Priority], 1, \"Critical\", 2, \"High\", 3, \"Medium\", 4, \"Low\", \"Unknown\")",
            "type": "calculated"
          },
          {
            "name": "StatusLabel",
            "dataType": "string",
            "isDataTypeInferred": false,
            "expression": "SWITCH([Status], 1, \"New\", 2, \"Assigned\", 3, \"In Progress\", 4, \"Waiting on Requester\", 5, \"Waiting on Third Party\", 6, \"Resolved\", 7, \"Closed\", 8, \"Cancelled\", \"Unknown\")",
            "type": "calculated"
          },
          {
            "name": "SourceLabel",
            "dataType": "string",
            "isDataTypeInferred": false,
            "expression": "SWITCH([Source], 1, \"Portal\", 2, \"Email\", 3, \"Teams Bot\", 4, \"Phone\", 5, \"Walk-up\", \"Unknown\")",
            "type": "calculated"
          }
        ],
