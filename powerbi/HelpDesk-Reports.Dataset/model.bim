          { "name": "AgentId", "dataType": "string", "sourceColumn": "AgentId", "isHidden": true },
          { "name": "TicketsAssigned", "dataType": "int64", "sourceColumn": "TicketsAssigned" },
          { "name": "TicketsResolved", "dataType": "int64", "sourceColumn": "TicketsResolved" },
          { "name": "AvgResolutionMinutes", "dataType": "double", "sourceColumn": "AvgResolutionMinutes" },
          { "name": "AvgSatisfaction", "dataType": "double", "sourceColumn": "AvgSatisfaction" },
          { "name": "SLABreachCount", "dataType": "int64", "sourceColumn": "SLABreachCount" }
        ],
