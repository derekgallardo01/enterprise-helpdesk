            }
          }
        ]
      },
      {
        "name": "_Measures",
        "columns": [],
        "measures": [
          {
            "name": "Total Tickets",
            "expression": "COUNTROWS(TicketFact)"
          },
          {
            "name": "Open Tickets",
            "expression": "CALCULATE(\n    COUNTROWS(TicketFact),\n    TicketFact[Status] IN {1, 2, 3, 4, 5}\n)"
          },
          {
            "name": "Resolved Tickets",
            "expression": "CALCULATE(\n    COUNTROWS(TicketFact),\n    TicketFact[Status] = 6\n)"
          },
          {
            "name": "Avg Resolution Hours",
            "expression": "DIVIDE(\n    AVERAGE(TicketFact[ResolutionMinutes]),\n    60,\n    BLANK()\n)",
            "formatString": "#,##0.0"
          },
          {
            "name": "SLA Compliance %",
            "expression": "VAR _Total = COUNTROWS(TicketFact)\nVAR _Breached = CALCULATE(COUNTROWS(TicketFact), TicketFact[SLABreached] = TRUE())\nRETURN\n    IF(\n        _Total > 0,\n        DIVIDE(_Total - _Breached, _Total) * 100,\n        BLANK()\n    )",
            "formatString": "#,##0.0\"%\""
          },
          {
            "name": "Avg Satisfaction",
            "expression": "AVERAGE(TicketFact[SatisfactionRating])",
            "formatString": "#,##0.00"
          },
          {
            "name": "First Response SLA %",
            "expression": "VAR _WithResponse = CALCULATE(\n    COUNTROWS(TicketFact),\n    NOT ISBLANK(TicketFact[FirstResponseAt])\n)\nVAR _OnTime = CALCULATE(\n    COUNTROWS(TicketFact),\n    NOT ISBLANK(TicketFact[FirstResponseAt]),\n    TicketFact[FirstResponseMinutes] <= 60\n)\nRETURN\n    IF(\n        _WithResponse > 0,\n        DIVIDE(_OnTime, _WithResponse) * 100,\n        BLANK()\n    )",
            "formatString": "#,##0.0\"%\""
          },
          {
            "name": "Tickets Trending (30-day)",
            "expression": "VAR _Last30 = CALCULATE(\n    COUNTROWS(TicketFact),\n    DATESINPERIOD(DateDim[FullDate], TODAY(), -30, DAY)\n)\nVAR _Prior30 = CALCULATE(\n    COUNTROWS(TicketFact),\n    DATESINPERIOD(DateDim[FullDate], TODAY() - 30, -30, DAY)\n)\nRETURN\n    IF(\n        _Prior30 > 0,\n        DIVIDE(_Last30 - _Prior30, _Prior30) * 100,\n        BLANK()\n    )",
            "formatString": "+#,##0.0\"%\";-#,##0.0\"%\";\"0.0%\""
          }
        ],
        "partitions": [
          {
            "name": "_Measures",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": "let\n    Source = #table(type table [], {})\nin\n    Source"
            }
          }
        ],
        "annotations": [
          {
            "name": "PBI_MeasuresTable",
            "value": "true"
          }
        ]
      }
